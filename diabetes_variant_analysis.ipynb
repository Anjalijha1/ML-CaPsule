import os
import zipfile
import matplotlib.pyplot as plt
import numpy as np
import pandas as pd
import seaborn as sns

# ==========================================
# 1. GLOBAL SETUP & CONFIGURATION
# ==========================================
# Apply a clean theme for all seaborn plots to ensure professional presentation.
sns.set_theme(style="whitegrid")
print("All necessary libraries imported and Seaborn theme applied.")

# Define the paths for the zip source and the target CSV file.
ZIP_SOURCE_PATH = "/content/archive (1).zip"
EXTRACTED_TARGET_CSV = "diabetes_dataset00.csv"


# ==========================================
# 2. DATA INGESTION FUNCTION
# ==========================================
def ingest_data(zip_path: str, csv_filename: str) -> pd.DataFrame:
    """Extracts a specified CSV file from a zip archive and loads it into a

    pandas DataFrame.
    """
    extraction_dir = "./extracted_data"
    os.makedirs(extraction_dir, exist_ok=True)

    try:
        with zipfile.ZipFile(zip_path, "r") as zip_ref:
            zip_ref.extract(csv_filename, extraction_dir)
        print(f"Successfully extracted '{csv_filename}' to '{extraction_dir}'.")

        df = pd.read_csv(os.path.join(extraction_dir, csv_filename))
        print(f"\nDataFrame loaded from '{csv_filename}'.")
        print(f"DataFrame shape: {df.shape}")
        print("\nFirst 5 rows of the DataFrame:")
        return df
    except FileNotFoundError as e:
        print(
            f"Error: {e}. Please ensure the zip file path and CSV filename are correct."
        )
        return pd.DataFrame()
    except KeyError:
        print(f"Error: '{csv_filename}' not found inside '{zip_path}'.")
        return pd.DataFrame()
    except Exception as e:
        print(f"An unexpected error occurred during data ingestion: {e}")
        return pd.DataFrame()


# Executing Ingestion
df = ingest_data(ZIP_SOURCE_PATH, EXTRACTED_TARGET_CSV)


# ==========================================
# 3. DATA QUALITY & ANOMALY PROFILING
# ==========================================
if not df.empty:
    # Initializing lists to capture data quality metrics
    feature_names = []
    percentage_anomalies = []

    # Loop across numeric columns to profile missing values and zero-placeholders
    for col in df.columns:
        if df[col].dtype not in [np.int64, np.float64]:
            continue

        # Calculate explicit NaNs
        nan_count = df[col].isnull().sum()

        # Calculate '0' values acting as placeholders for missing data
        zero_count = (df[col] == 0).sum()

        total_rows = len(df)
        combined_anomalies_count = nan_count + zero_count
        percentage = (
            (combined_anomalies_count / total_rows) * 100
            if total_rows > 0
            : 0
        )

        feature_names.append(col)
        percentage_anomalies.append(percentage)

    # Create a DataFrame from the calculated anomaly percentages for plotting
    anomaly_df = pd.DataFrame(
        {"Feature": feature_names, "Anomaly Percentage": percentage_anomalies}
    )

    # Set up and generate the data quality visualization
    plt.figure(figsize=(9, 6))
    ax = sns.barplot(
        x="Feature",
        y="Anomaly Percentage",
        data=anomaly_df,
        palette="Reds_d",
    )

    # Overlay exact percentage labels on top of each bar
    for p in ax.patches:
        height = p.get_height()
        ax.text(
            p.get_x() + p.get_width() / 2.0,  # Center horizontally
            height + 0.5,  # Position slightly above the bar top
            f"{height:.2f}%",
            ha="center",
            va="bottom",
        )

    plt.title("Feature-wise Anomaly and Missing Data Percentage")
    plt.xticks(rotation=45)
    plt.tight_layout()
    plt.show()
else:
    print(
        "DataFrame is empty. Skipping anomaly profiling and visualization steps."
